generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient            Patient?
  doctorAppointments Appointment[] @relation("DoctorAppointments")
  auditLogs          AuditLog[]
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  FRONT_DESK
  BILLING
  PATIENT
}

model Patient {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  firstName    String
  lastName     String
  dob          DateTime
  gender       Gender
  phone        String
  address      String?
  appointments Appointment[]
  queue        Queue[]
  billing      Billing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  resource   String
  resourceId String
  details    String?
  timestamp  DateTime @default(now())
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id String @id @default(uuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  doctorId String?
  doctor   User?   @relation("DoctorAppointments", fields: [doctorId], references: [id])

  dateTime DateTime
  reason   String
  status   AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Queue {
  id String @id @default(uuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  queueNumber Int
  status      QueueStatus @default(WAITING)

  createdAt DateTime  @default(now())
  calledAt  DateTime? // When doctor called them
}

enum QueueStatus {
  WAITING
  CALLED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

model Billing {
  id String @id @default(uuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  appointmentId String?

  amount      Float
  description String
  status      BillingStatus @default(PENDING)

  createdAt DateTime  @default(now())
  paidAt    DateTime?
}

enum BillingStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
}
